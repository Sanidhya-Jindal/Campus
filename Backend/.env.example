# Copy to .env and fill in real values.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL (must have the pgvector extension available)
DB_NAME=campus_sentinel
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Google Gemini. Used by the summarizer, occupancy explainer and alert
# recommender. If unset, those features degrade gracefully and are skipped.
GEMINI_API_KEY=your_gemini_api_key_here
