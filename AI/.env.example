# Copy to .env and fill in real values.

# Google Gemini. Required: AI/Agent/agent.py raises at import if this is unset.
GEMINI_API_KEY=your_gemini_api_key_here

# Credentials the agent uses to log in to the Django backend on startup.
# Must match a user registered via POST /users/register/.
AGENT_EMAIL=agent@example.com
AGENT_PASSWORD=your_agent_password

# Django backend base URL (used by AI/Agent/tools.py)
API_BASE_URL=http://127.0.0.1:8000

# Face search endpoint (used by AI/face_embedding.py)
DRF_SEARCH_URL=http://127.0.0.1:8000/api/search/face/
